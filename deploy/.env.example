# Porta da aplicação (Hostinger normalmente injeta automaticamente)
PORT=3000

# Ambiente
NODE_ENV=production

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Segredo JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque-por-uma-chave-aleatoria-de-no-minimo-64-caracteres

# Domínio do frontend (CORS) — sem barra no final
CORS_ORIGIN=https://seudominio.com.br

# Cloudinary (opcional — necessário apenas se usar upload de fotos/evolução)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
